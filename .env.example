# ── BitGet API (Ironclad + HYPE Manager) ─────────────────────────────────────
# Create at: BitGet → Profile → API Management → Create API
# Permissions needed: Read-Write Futures Orders, Read-Write Spot Trading
# IMPORTANT: passphrase must be alphanumeric only — no $, @, ! etc
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# ── Paper trading flags ───────────────────────────────────────────────────────
# Set to the string "false" (not blank, not 0) when ready to go live
# Leaving blank or missing defaults to paper mode
PAPER_TRADING=true
IRONCLAD_PAPER=true
SID_PAPER=true

# ── Ironclad position sizing ──────────────────────────────────────────────────
PORTFOLIO_USD=500         # Total account size in USD
MAX_TRADE_USD=50          # Max USD risked per trade (1% of portfolio)
LEVERAGE=3                # Futures leverage (set same value on BitGet manually)
MAX_TRADES_PER_DAY=3      # Max new entries per bot run cycle

# ── Trading mode ──────────────────────────────────────────────────────────────
MODE=futures

# ── HYPE manual position (set from your BitGet position details) ──────────────
# Used by bot-hype-manager.js to manage TP/SL without needing position-read API permission
HYPE_QTY=0                # Your HYPE position size in coins (0 = manager skips)
HYPE_ENTRY=0              # Your average entry price

# ── Research agent ────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=

# ── Voice Claude (voice-claude.js) ────────────────────────────────────────────
# Get Anthropic key at: https://console.anthropic.com  (required)
ANTHROPIC_API_KEY=
# Get ElevenLabs key at: https://elevenlabs.io  (optional — much better voice quality)
# Free tier: 10,000 characters/month
ELEVENLABS_API_KEY=
# Optional: override the default voice. Find IDs at https://elevenlabs.io/voice-library
# Default is Charlotte (British female). Leave blank to use the default.
ELEVENLABS_VOICE_ID=

# ── GitHub state sync (Railway only) ─────────────────────────────────────────
# Fine-grained PAT: Contents read+write on your trading repo
# Create at: GitHub → Settings → Developer Settings → Personal Access Tokens
GITHUB_TOKEN=

# ── SID Stock Swing ───────────────────────────────────────────────────────────
SID_ACCOUNT_USD=5000      # Starting capital (only used on first run — tracked in sid-account.json after)
SID_RISK_PCT=0.005        # 0.5% risk per trade
SID_MAX_POS_PCT=0.10      # Max 10% of account per position
SID_MAX_POSITIONS=3       # Max open positions at once
SID_MAX_PER_DAY=1         # Max new entries per run
SID_EARNINGS_WINDOW=14    # Skip trades within 14 days of earnings
