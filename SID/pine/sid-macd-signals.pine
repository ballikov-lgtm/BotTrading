//@version=6
// =============================================================================
// SID MACD Signals v1.6
// =============================================================================
// Companion indicator to sid-strategy.pine v1.6. Plots the daily MACD on its
// own pane with arrows that match the strategy's v1.6 filter logic.
//
// v1.6 filters (mirror the strategy):
//   - RSI(3) rebound-zone confirmation
//   - Weekly trend filter
// =============================================================================

indicator(
   "SID MACD Signals v1.6",
   shorttitle = "SID MACD",
   overlay    = false,
   format     = format.price,
   precision  = 4
   )

g_m = "MACD"
i_fast   = input.int(12, "MACD fast",   minval=2, group=g_m)
i_slow   = input.int(26, "MACD slow",   minval=2, group=g_m)
i_signal = input.int(9,  "MACD signal", minval=2, group=g_m)

g_r = "Rules"
i_rsiOversold   = input.int(30, "RSI oversold (long signal)",  minval=10, maxval=45, group=g_r)
i_rsiOverbought = input.int(75, "RSI overbought (short signal)", minval=55, maxval=90, group=g_r)
i_rsi3Length    = input.int(3,  "RSI(3) length", minval=2, maxval=10, group=g_r)
i_timeoutDays   = input.int(3,  "Sticky-arm timeout (days)", minval=1, maxval=10, group=g_r)

g_filt = "Confirmation filters"
i_useRsi3        = input.bool(true, "RSI(3) confirmation", group=g_filt)
i_useWeeklyTrend = input.bool(true, "Weekly trend filter", group=g_filt)
i_wkFastSMA      = input.int(50,  "Weekly fast SMA",  minval=10, maxval=100, group=g_filt)
i_wkSlowSMA      = input.int(200, "Weekly slow SMA", minval=50, maxval=300, group=g_filt)

g_d = "Display"
i_showHist   = input.bool(true, "Show histogram", group=g_d)
i_showArrows = input.bool(true, "Show entry arrows", group=g_d)
i_showArmDot = input.bool(true, "Show signal-arm dot", group=g_d)

[macdLine_, macdSig_, macdHist_] = ta.macd(close, i_fast, i_slow, i_signal)
dailyMACD     = request.security(syminfo.tickerid, "D", macdLine_,    lookahead=barmerge.lookahead_off)
dailyMACDPrev = request.security(syminfo.tickerid, "D", macdLine_[1], lookahead=barmerge.lookahead_off)
dailySignal   = request.security(syminfo.tickerid, "D", macdSig_,     lookahead=barmerge.lookahead_off)
dailyHist     = request.security(syminfo.tickerid, "D", macdHist_,    lookahead=barmerge.lookahead_off)

dailyRSI     = request.security(syminfo.tickerid, "D", ta.rsi(close, 14),               lookahead=barmerge.lookahead_off)
dailyRSIPrev = request.security(syminfo.tickerid, "D", ta.rsi(close, 14)[1],            lookahead=barmerge.lookahead_off)
dailyRSI3    = request.security(syminfo.tickerid, "D", ta.rsi(close, i_rsi3Length),     lookahead=barmerge.lookahead_off)

wkFast      = request.security(syminfo.tickerid, "W", ta.sma(close, i_wkFastSMA), lookahead=barmerge.lookahead_off)
wkSlow      = request.security(syminfo.tickerid, "W", ta.sma(close, i_wkSlowSMA), lookahead=barmerge.lookahead_off)
wkUptrend   = not na(wkFast) and not na(wkSlow) and wkFast > wkSlow
wkDowntrend = not na(wkFast) and not na(wkSlow) and wkFast < wkSlow

rsiRising   = dailyRSI  > dailyRSIPrev
rsiFalling  = dailyRSI  < dailyRSIPrev
macdRising  = dailyMACD > dailyMACDPrev
macdFalling = dailyMACD < dailyMACDPrev

isNewDailyBar = ta.change(time("D")) != 0
isOversold    = dailyRSI < i_rsiOversold
isOverbought  = dailyRSI > i_rsiOverbought

rsi3OkLong  = not i_useRsi3 or (not na(dailyRSI3) and dailyRSI3 < i_rsiOversold)
rsi3OkShort = not i_useRsi3 or (not na(dailyRSI3) and dailyRSI3 > i_rsiOverbought)
wkOkLong    = not i_useWeeklyTrend or wkUptrend
wkOkShort   = not i_useWeeklyTrend or wkDowntrend

var string armDir       = na
var int    daysSinceArm = 0

canArm = na(armDir)
shouldArmLong  = isNewDailyBar and canArm and isOversold   and rsi3OkLong  and wkOkLong
shouldArmShort = isNewDailyBar and canArm and isOverbought and rsi3OkShort and wkOkShort

if shouldArmLong
    armDir       := "LONG"
    daysSinceArm := 0
if shouldArmShort
    armDir       := "SHORT"
    daysSinceArm := 0

if not na(armDir) and isNewDailyBar and not (shouldArmLong or shouldArmShort)
    daysSinceArm := daysSinceArm + 1
    if daysSinceArm >= i_timeoutDays
        armDir       := na
        daysSinceArm := 0

entryReadyLong  = armDir == "LONG"  and isNewDailyBar and rsiRising  and macdRising
entryReadyShort = armDir == "SHORT" and isNewDailyBar and rsiFalling and macdFalling

if entryReadyLong or entryReadyShort
    armDir       := na
    daysSinceArm := 0

// --- Plots -----------------------------------------------------------------
histColor = dailyHist >= 0 ? (dailyHist > dailyHist[1] ? color.new(#26a69a, 0) : color.new(#26a69a, 40))
                          : (dailyHist < dailyHist[1] ? color.new(#ef5350, 0) : color.new(#ef5350, 40))
plot(i_showHist ? dailyHist : na, "Histogram", color=histColor, style=plot.style_columns)
plot(dailyMACD,   "MACD",   color=color.new(#2962ff, 0), linewidth=2)
plot(dailySignal, "Signal", color=color.new(#ff6d00, 0), linewidth=1)
hline(0, "Zero", color=color.new(#8b949e, 40), linestyle=hline.style_dotted)

plotshape(i_showArmDot and (shouldArmLong or shouldArmShort),
   title="Signal armed (RSI extreme + filters)",
   style=shape.circle, location=location.absolute,
   color=color.new(color.yellow, 30), size=size.tiny)

plotshape(i_showArrows and entryReadyShort,
   title="Entry Short — MACD ↓ aligned",
   style=shape.arrowdown, location=location.absolute,
   color=color.new(#f85149, 0), size=size.large,
   text="↓ ENTRY", textcolor=color.white)

plotshape(i_showArrows and entryReadyLong,
   title="Entry Long — MACD ↑ aligned",
   style=shape.arrowup, location=location.absolute,
   color=color.new(#3fb950, 0), size=size.large,
   text="↑ ENTRY", textcolor=color.white)
