//@version=6
// =============================================================================
// SID RSI Signals v1.7
// =============================================================================
// Companion indicator to sid-strategy.pine v1.7. Plots the daily RSI(14) on
// its own pane with built-in 30 / 50 / 75 lines and arrows that fire at the
// same signal/entry events as the strategy.
//
// v1.7 filters (mirror the strategy):
//   - RSI(3) rebound-zone confirmation: 3-day RSI must also be in extreme
//   - Weekly trend filter: longs only in weekly uptrend (50w SMA > 200w SMA)
//
// Toggles match the strategy script — keep them aligned.
// =============================================================================

indicator(
   "SID RSI Signals v1.7",
   shorttitle = "SID RSI",
   overlay    = false,
   format     = format.price,
   precision  = 1,
   scale      = scale.right
   )

g_r = "Rules"
i_rsiLength     = input.int(14, "RSI(14) length", minval=2, group=g_r)
i_rsi3Length    = input.int(3,  "RSI(3) confirmation length", minval=2, maxval=10, group=g_r)
i_rsiOversold   = input.int(30, "RSI oversold (long signal)",  minval=10, maxval=45, group=g_r)
i_rsiOverbought = input.int(75, "RSI overbought (short signal)", minval=55, maxval=90, group=g_r)
i_rsiExit       = input.int(50, "RSI exit (midline)", minval=30, maxval=70, group=g_r)
i_timeoutDays   = input.int(3,  "Sticky-arm timeout (days)", minval=1, maxval=10, group=g_r)

g_filt = "Confirmation filters (match strategy)"
i_useRsi3        = input.bool(true,  "RSI(3) confirmation", group=g_filt)
i_useWeeklyTrend = input.bool(true,  "Weekly trend filter", group=g_filt)
i_wkFastSMA      = input.int(50,  "Weekly fast SMA",  minval=10, maxval=100, group=g_filt)
i_wkSlowSMA      = input.int(200, "Weekly slow SMA", minval=50, maxval=300, group=g_filt)

g_d = "Display"
i_showLabels = input.bool(true, "Show OB/OS text labels", group=g_d)
i_showArrows = input.bool(true, "Show signal + entry arrows", group=g_d)

dailyRSI     = request.security(syminfo.tickerid, "D", ta.rsi(close, i_rsiLength),   lookahead=barmerge.lookahead_off)
dailyRSIPrev = request.security(syminfo.tickerid, "D", ta.rsi(close, i_rsiLength)[1], lookahead=barmerge.lookahead_off)
dailyRSI3    = request.security(syminfo.tickerid, "D", ta.rsi(close, i_rsi3Length),  lookahead=barmerge.lookahead_off)

[macdLine_, _, _] = ta.macd(close, 12, 26, 9)
dailyMACD     = request.security(syminfo.tickerid, "D", macdLine_,    lookahead=barmerge.lookahead_off)
dailyMACDPrev = request.security(syminfo.tickerid, "D", macdLine_[1], lookahead=barmerge.lookahead_off)

rsiRising   = dailyRSI > dailyRSIPrev
rsiFalling  = dailyRSI < dailyRSIPrev
macdRising  = dailyMACD > dailyMACDPrev
macdFalling = dailyMACD < dailyMACDPrev

isNewDailyBar = ta.change(time("D")) != 0
isOversold    = dailyRSI < i_rsiOversold
isOverbought  = dailyRSI > i_rsiOverbought

// Weekly trend (mirror strategy)
wkFast       = request.security(syminfo.tickerid, "W", ta.sma(close, i_wkFastSMA), lookahead=barmerge.lookahead_off)
wkSlow       = request.security(syminfo.tickerid, "W", ta.sma(close, i_wkSlowSMA), lookahead=barmerge.lookahead_off)
wkUptrend    = not na(wkFast) and not na(wkSlow) and wkFast > wkSlow
wkDowntrend  = not na(wkFast) and not na(wkSlow) and wkFast < wkSlow

// Confirmation gates
rsi3OkLong  = not i_useRsi3 or (not na(dailyRSI3) and dailyRSI3 < i_rsiOversold)
rsi3OkShort = not i_useRsi3 or (not na(dailyRSI3) and dailyRSI3 > i_rsiOverbought)
wkOkLong    = not i_useWeeklyTrend or wkUptrend
wkOkShort   = not i_useWeeklyTrend or wkDowntrend

// Sticky-arm state machine
var string armDir       = na
var int    daysSinceArm = 0

canArm = na(armDir)
shouldArmLong  = isNewDailyBar and canArm and isOversold   and rsi3OkLong  and wkOkLong
shouldArmShort = isNewDailyBar and canArm and isOverbought and rsi3OkShort and wkOkShort

if shouldArmLong
    armDir       := "LONG"
    daysSinceArm := 0
if shouldArmShort
    armDir       := "SHORT"
    daysSinceArm := 0

if not na(armDir) and isNewDailyBar and not (shouldArmLong or shouldArmShort)
    daysSinceArm := daysSinceArm + 1
    if daysSinceArm >= i_timeoutDays
        armDir       := na
        daysSinceArm := 0

// Entry alignment
entryReadyLong  = armDir == "LONG"  and isNewDailyBar and rsiRising  and macdRising
entryReadyShort = armDir == "SHORT" and isNewDailyBar and rsiFalling and macdFalling

if entryReadyLong or entryReadyShort
    armDir       := na
    daysSinceArm := 0

// --- Plots -----------------------------------------------------------------
plot(dailyRSI,  "RSI(14)", color=color.new(#7e57c2, 0), linewidth=2)
plot(dailyRSI3, "RSI(3) confirm", color=color.new(#ff9800, 50), linewidth=1, display=i_useRsi3 ? display.all : display.none)

hline(i_rsiOverbought, "Overbought 75", color=color.new(#f85149, 30), linestyle=hline.style_dashed)
hline(i_rsiExit,       "Midline 50",    color=color.new(#8b949e, 60), linestyle=hline.style_dotted)
hline(i_rsiOversold,   "Oversold 30",   color=color.new(#3fb950, 30), linestyle=hline.style_dashed)

bgcolor(isOverbought ? color.new(#f85149, 92) : na, title="Overbought shade")
bgcolor(isOversold   ? color.new(#3fb950, 92) : na, title="Oversold shade")

// Arrows on the RSI pane
plotshape(i_showArrows and shouldArmShort,
   title="Signal Short — Overbought (all filters)",
   style=shape.arrowdown, location=location.absolute,
   color=color.new(#f85149, 0), size=size.normal,
   text="OB", textcolor=color.white)

plotshape(i_showArrows and shouldArmLong,
   title="Signal Long — Oversold (all filters)",
   style=shape.arrowup, location=location.absolute,
   color=color.new(#3fb950, 0), size=size.normal,
   text="OS", textcolor=color.white)

plotshape(i_showArrows and entryReadyShort,
   title="Entry Short — RSI+MACD aligned",
   style=shape.arrowdown, location=location.absolute,
   color=color.new(#ff7b72, 0), size=size.large,
   text="ENTRY", textcolor=color.white)

plotshape(i_showArrows and entryReadyLong,
   title="Entry Long — RSI+MACD aligned",
   style=shape.arrowup, location=location.absolute,
   color=color.new(#56d364, 0), size=size.large,
   text="ENTRY", textcolor=color.white)

if i_showLabels and shouldArmShort
    label.new(bar_index, dailyRSI + 8, "OVERBOUGHT", color=color.new(#f85149, 30),
              textcolor=color.white, style=label.style_label_down, size=size.small)
if i_showLabels and shouldArmLong
    label.new(bar_index, dailyRSI - 8, "OVERSOLD", color=color.new(#3fb950, 30),
              textcolor=color.white, style=label.style_label_up, size=size.small)
