//@version=6
// =============================================================================
// SID Strategy v1.2  — Instructor-aligned (proven 70%+ over 300 trades)
// =============================================================================
// CORE RULES (from the SID instructor's method — DO NOT MODIFY):
//   1. Signal:  RSI(14) crosses below 30 (LONG) or above 70 (SHORT). This is
//               the "signal date" and the trade is ARMED. RSI does NOT need to
//               stay in the extreme zone afterwards — the arm is STICKY.
//   2. Earnings: Skip the trade if earnings within 14 calendar days.
//   3. Entry:   On a LATER day (signal day + 1 to 3 trading days), when daily
//               RSI direction AND daily MACD direction both point in trade
//               direction simultaneously. Entry is on that daily close.
//   4. Stop:    Lowest low (long) / highest high (short) between signal day
//               and entry day, rounded DOWN/UP to whole dollar.
//   5. Exit:    Daily RSI reaches 50. Single full exit.
//
// MINOR BOT-SPECIFIC TWEAKS (allowed per project policy):
//   - Optional 15-min intraday confirmation candle (default ON)
//   - 3-day hard timeout on armed signals
//   - Earnings blackout window configurable
//   - Position sizing via account size × risk %
//
// VERSION HISTORY:
//   v1.0 — initial: simultaneous RSI+MACD daily-bar arm/entry
//   v1.1 — added 15-min intraday entry confirmation + 3-day timeout
//   v1.2 — INSTRUCTOR-ALIGNED FIX: arm on RSI-extreme alone (sticky); entry
//          is RSI+MACD direction-align on a LATER day. Caught the bug where
//          v1.1 required RSI to still be in extreme zone at entry, which is
//          NOT the instructor's rule. (Discovered via Project D analysis.)
//
// USAGE: Apply to a 15-minute chart on any US stock or ETF.
//        Open the Strategy Tester to see backtest performance.
//        Optionally add: sid-rsi-signals.pine + sid-macd-signals.pine indicators
//        for matching arrows on the RSI and MACD panes.
// =============================================================================

strategy(
   "SID Strategy v1.2",
   shorttitle           = "SID v1.2",
   overlay              = true,
   initial_capital      = 10000,
   default_qty_type     = strategy.fixed,
   default_qty_value    = 0,
   pyramiding           = 0,
   process_orders_on_close = true,
   calc_on_every_tick   = false,
   commission_type      = strategy.commission.percent,
   commission_value     = 0.0,
   slippage             = 0
   )

// --- Inputs ----------------------------------------------------------------
g_strat = "Strategy"
i_accountSize   = input.float(10000.0, "Account size ($)", minval=100, group=g_strat)
i_riskPct       = input.float(0.5,    "Risk per trade (%)", minval=0.1, maxval=5.0, step=0.1, group=g_strat,
   tooltip="Start at 0.5% while paper trading; move to 1-2% once live and consistently profitable.")
i_rsiOversold   = input.int(30,       "RSI oversold (long signal)",   minval=10, maxval=45, group=g_strat)
i_rsiOverbought = input.int(70,       "RSI overbought (short signal)", minval=55, maxval=90, group=g_strat)
i_rsiExit       = input.int(50,       "RSI exit level", minval=30, maxval=70, group=g_strat)
i_timeoutDays   = input.int(3,        "Hard timeout (trading days)", minval=1, maxval=10, group=g_strat)

g_filt = "Filters"
i_allowLongs    = input.bool(true,  "Allow long trades",  group=g_filt)
i_allowShorts   = input.bool(true,  "Allow short trades", group=g_filt)
i_useEarnings   = input.bool(true,  "Apply 14-day earnings blackout", group=g_filt)
i_earningsDays  = input.int(14,     "Earnings blackout days",  minval=1, maxval=30, group=g_filt)
i_useIntraday   = input.bool(true,  "Use 15-min intraday entry confirmation",  group=g_filt,
   tooltip="When ON, requires a 15-min candle in trade direction during US session AFTER the daily alignment fires. Acts as a fake-reversal filter. v1.1 minor tweak; turn OFF for pure instructor method.")

g_disp = "Display"
i_showTable   = input.bool(true,  "Show info table",                group=g_disp)
i_showSignals = input.bool(true,  "Show signal + entry markers",    group=g_disp)
i_showStops   = input.bool(true,  "Show stop line while in trade",  group=g_disp)

// --- Daily-timeframe values ------------------------------------------------
[macdLine_, macdSig_, _] = ta.macd(close, 12, 26, 9)

dailyRSI       = request.security(syminfo.tickerid, "D", ta.rsi(close, 14),       lookahead=barmerge.lookahead_off)
dailyRSIPrev   = request.security(syminfo.tickerid, "D", ta.rsi(close, 14)[1],    lookahead=barmerge.lookahead_off)
dailyMACDLine  = request.security(syminfo.tickerid, "D", macdLine_,               lookahead=barmerge.lookahead_off)
dailyMACDPrev  = request.security(syminfo.tickerid, "D", macdLine_[1],            lookahead=barmerge.lookahead_off)
dailyLow       = request.security(syminfo.tickerid, "D", low,                     lookahead=barmerge.lookahead_off)
dailyHigh      = request.security(syminfo.tickerid, "D", high,                    lookahead=barmerge.lookahead_off)

rsiRising      = dailyRSI > dailyRSIPrev
rsiFalling     = dailyRSI < dailyRSIPrev
macdRising     = dailyMACDLine > dailyMACDPrev
macdFalling    = dailyMACDLine < dailyMACDPrev

// --- Earnings filter -------------------------------------------------------
nextEarningsTime = request.security(syminfo.tickerid, "D", earnings.future_time, ignore_invalid_symbol=true, lookahead=barmerge.lookahead_off)
hasEarnings      = not na(nextEarningsTime)
daysToEarnings   = hasEarnings ? math.floor((nextEarningsTime - time) / (1000.0 * 60.0 * 60.0 * 24.0)) : 9999
earningsBlackout = i_useEarnings and hasEarnings and daysToEarnings <= i_earningsDays

// --- Daily-bar boundary detection ------------------------------------------
isNewDailyBar = ta.change(time("D")) != 0

// --- Signal arming (sticky — RSI extreme alone) ----------------------------
// Instructor rule 1: signal date = day RSI hits extreme zone.
// Bot adds: must be a NEW daily bar, no current arm/position, no earnings blackout.
isOversold   = dailyRSI < i_rsiOversold
isOverbought = dailyRSI > i_rsiOverbought

var string armDir          = na
var int    armStartBarIdx  = na
var float  armSignalLow    = na
var float  armSignalHigh   = na
var int    daysSinceArm    = 0

canArm = na(armDir) and strategy.position_size == 0 and not earningsBlackout

shouldArmLong  = isNewDailyBar and canArm and i_allowLongs  and isOversold
shouldArmShort = isNewDailyBar and canArm and i_allowShorts and isOverbought

if shouldArmLong
    armDir         := "LONG"
    armStartBarIdx := bar_index
    armSignalLow   := dailyLow
    armSignalHigh  := dailyHigh
    daysSinceArm   := 0

if shouldArmShort
    armDir         := "SHORT"
    armStartBarIdx := bar_index
    armSignalLow   := dailyLow
    armSignalHigh  := dailyHigh
    daysSinceArm   := 0

// While armed, track extremes for stop calc + day counter
if not na(armDir) and isNewDailyBar and not (shouldArmLong or shouldArmShort)
    daysSinceArm  := daysSinceArm + 1
    armSignalLow  := math.min(armSignalLow,  dailyLow)
    armSignalHigh := math.max(armSignalHigh, dailyHigh)

// --- Invalidation: timeout OR earnings (per instructor — no RSI-zone exit) -
invalidLong  = armDir == "LONG"  and isNewDailyBar and (daysSinceArm >= i_timeoutDays or earningsBlackout)
invalidShort = armDir == "SHORT" and isNewDailyBar and (daysSinceArm >= i_timeoutDays or earningsBlackout)

if invalidLong or invalidShort
    armDir         := na
    armStartBarIdx := na
    armSignalLow   := na
    armSignalHigh  := na
    daysSinceArm   := 0

// --- Entry conditions ------------------------------------------------------
// Instructor rule 3: when armed, enter when daily RSI direction AND daily MACD
// direction both point in trade direction (on a later daily bar).
dailyEntryArmedLong  = armDir == "LONG"  and isNewDailyBar and rsiRising  and macdRising
dailyEntryArmedShort = armDir == "SHORT" and isNewDailyBar and rsiFalling and macdFalling

// Persist the "daily entry ready" state through the day so the 15-min check can fire on later 15-min bars
var bool dailyReadyLong  = false
var bool dailyReadyShort = false

if isNewDailyBar
    dailyReadyLong  := dailyEntryArmedLong
    dailyReadyShort := dailyEntryArmedShort

// Optional: 15-min intraday confirmation (v1.1 carry-over minor tweak)
inUSSession = not na(time(timeframe.period, "0930-1600", "America/New_York"))
candleGreen = close > open
candleRed   = close < open

readyToEnterLong  = i_useIntraday ? (dailyReadyLong  and armDir == "LONG"  and inUSSession and candleGreen) : dailyEntryArmedLong
readyToEnterShort = i_useIntraday ? (dailyReadyShort and armDir == "SHORT" and inUSSession and candleRed)   : dailyEntryArmedShort

// --- Position sizing -------------------------------------------------------
riskAmount = i_accountSize * (i_riskPct / 100.0)
stopLong   = na(armSignalLow)  ? na : math.floor(armSignalLow)
stopShort  = na(armSignalHigh) ? na : math.ceil(armSignalHigh)

riskPerShareLong  = readyToEnterLong  and not na(stopLong)  ? close - stopLong  : na
riskPerShareShort = readyToEnterShort and not na(stopShort) ? stopShort - close : na

sharesLong  = not na(riskPerShareLong)  and riskPerShareLong  > 0 ? math.floor(riskAmount / riskPerShareLong)  : 0
sharesShort = not na(riskPerShareShort) and riskPerShareShort > 0 ? math.floor(riskAmount / riskPerShareShort) : 0

// --- Execute entries -------------------------------------------------------
if readyToEnterLong and sharesLong > 0
    strategy.entry("Long", strategy.long, qty=sharesLong)
    strategy.exit("Stop L", from_entry="Long", stop=stopLong)
    armDir         := na
    armStartBarIdx := na
    armSignalLow   := na
    armSignalHigh  := na
    daysSinceArm   := 0
    dailyReadyLong  := false

if readyToEnterShort and sharesShort > 0
    strategy.entry("Short", strategy.short, qty=sharesShort)
    strategy.exit("Stop S", from_entry="Short", stop=stopShort)
    armDir         := na
    armStartBarIdx := na
    armSignalLow   := na
    armSignalHigh  := na
    daysSinceArm   := 0
    dailyReadyShort := false

// --- Exit on daily RSI = 50 (instructor rule 5) ----------------------------
if strategy.position_size > 0 and dailyRSI >= i_rsiExit
    strategy.close("Long", comment="RSI 50 exit")

if strategy.position_size < 0 and dailyRSI <= i_rsiExit
    strategy.close("Short", comment="RSI 50 exit")

// --- On-chart markers (price pane) -----------------------------------------
// Signal armed (small triangle): yellow, at the signal day
plotshape(i_showSignals and shouldArmLong,  title="Long signal armed",
   style=shape.triangleup,   location=location.belowbar, color=color.new(color.yellow, 0), size=size.tiny)
plotshape(i_showSignals and shouldArmShort, title="Short signal armed",
   style=shape.triangledown, location=location.abovebar, color=color.new(color.yellow, 0), size=size.tiny)

// Entry confirmed (BIG arrow): green up / red down, at the entry day
plotshape(i_showSignals and readyToEnterLong  and sharesLong  > 0, title="Long entry",
   style=shape.arrowup,      location=location.belowbar, color=color.new(color.lime,    0), size=size.large)
plotshape(i_showSignals and readyToEnterShort and sharesShort > 0, title="Short entry",
   style=shape.arrowdown,    location=location.abovebar, color=color.new(color.fuchsia, 0), size=size.large)

// Exit marker
exitLong  = strategy.position_size[1] > 0 and dailyRSI >= i_rsiExit
exitShort = strategy.position_size[1] < 0 and dailyRSI <= i_rsiExit
plotshape(i_showSignals and exitLong,  title="Long exit",  style=shape.xcross, location=location.abovebar, color=color.new(color.orange, 0), size=size.normal)
plotshape(i_showSignals and exitShort, title="Short exit", style=shape.xcross, location=location.belowbar, color=color.new(color.orange, 0), size=size.normal)

// Stop level dot while in trade
inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0
plot(i_showStops and inLong  ? strategy.position_avg_price : na, "Long entry price",  color=color.new(color.green, 50), style=plot.style_circles, linewidth=1)
plot(i_showStops and inShort ? strategy.position_avg_price : na, "Short entry price", color=color.new(color.red,   50), style=plot.style_circles, linewidth=1)

// --- Info table ------------------------------------------------------------
if i_showTable and barstate.islast
    var table info = table.new(position.top_right, 2, 11, bgcolor=color.new(color.black, 70), border_width=1, border_color=color.new(color.gray, 50))

    state     = strategy.position_size != 0 ? (inLong ? "IN TRADE (LONG)" : "IN TRADE (SHORT)") : (na(armDir) ? "IDLE" : "ARMED " + armDir)
    rsiColor  = dailyRSI < i_rsiOversold ? color.lime : dailyRSI > i_rsiOverbought ? color.red : color.white
    macdTxt   = macdRising ? "rising" : macdFalling ? "falling" : "flat"
    macdCol   = macdRising ? color.lime : macdFalling ? color.red : color.gray
    rsiDirTxt = rsiRising ? "rising" : rsiFalling ? "falling" : "flat"
    rsiDirCol = rsiRising ? color.lime : rsiFalling ? color.red : color.gray
    earnTxt   = not hasEarnings ? "none" : (daysToEarnings <= i_earningsDays ? "BLACKOUT " + str.tostring(daysToEarnings) + "d" : str.tostring(daysToEarnings) + "d")
    earnCol   = earningsBlackout ? color.red : color.white
    stopTxt   = armDir == "LONG" ? "$" + str.tostring(stopLong, "#.##") : armDir == "SHORT" ? "$" + str.tostring(stopShort, "#.##") : "—"

    table.cell(info, 0, 0, "SID Strategy v1.2", text_color=color.white, bgcolor=color.new(color.blue, 40))
    table.cell(info, 1, 0, syminfo.ticker,      text_color=color.white, bgcolor=color.new(color.blue, 40))

    table.cell(info, 0, 1, "State",            text_color=color.gray)
    table.cell(info, 1, 1, state,              text_color=color.yellow)

    table.cell(info, 0, 2, "Daily RSI(14)",    text_color=color.gray)
    table.cell(info, 1, 2, str.tostring(dailyRSI, "#.#"), text_color=rsiColor)

    table.cell(info, 0, 3, "RSI direction",    text_color=color.gray)
    table.cell(info, 1, 3, rsiDirTxt,          text_color=rsiDirCol)

    table.cell(info, 0, 4, "MACD direction",   text_color=color.gray)
    table.cell(info, 1, 4, macdTxt,            text_color=macdCol)

    table.cell(info, 0, 5, "Days armed",       text_color=color.gray)
    table.cell(info, 1, 5, na(armDir) ? "—" : str.tostring(daysSinceArm) + " / " + str.tostring(i_timeoutDays), text_color=color.white)

    table.cell(info, 0, 6, "Earnings",         text_color=color.gray)
    table.cell(info, 1, 6, earnTxt,            text_color=earnCol)

    table.cell(info, 0, 7, "Stop level",       text_color=color.gray)
    table.cell(info, 1, 7, stopTxt,            text_color=color.white)

    table.cell(info, 0, 8, "Intraday confirm", text_color=color.gray)
    table.cell(info, 1, 8, i_useIntraday ? "ON (v1.1 tweak)" : "OFF (pure)", text_color=i_useIntraday ? color.aqua : color.gray)

    table.cell(info, 0, 9, "Risk per trade",   text_color=color.gray)
    table.cell(info, 1, 9, "$" + str.tostring(riskAmount, "#.##") + "  (" + str.tostring(i_riskPct) + "%)", text_color=color.white)

    table.cell(info, 0, 10, "Account",         text_color=color.gray)
    table.cell(info, 1, 10, "$" + str.tostring(i_accountSize, "#.##"), text_color=color.white)

// --- Alerts (webhook-ready JSON payloads for Telegram bridge) --------------
alertcondition(shouldArmLong,
   title="SID v1.2 - Long signal ARMED",
   message='{"version":"1.2","strategy":"SID","symbol":"{{ticker}}","state":"ARMED","direction":"LONG","close":{{close}},"time":"{{time}}"}')

alertcondition(shouldArmShort,
   title="SID v1.2 - Short signal ARMED",
   message='{"version":"1.2","strategy":"SID","symbol":"{{ticker}}","state":"ARMED","direction":"SHORT","close":{{close}},"time":"{{time}}"}')

alertcondition(readyToEnterLong and sharesLong > 0,
   title="SID v1.2 - Long entry CONFIRMED",
   message='{"version":"1.2","strategy":"SID","symbol":"{{ticker}}","state":"ENTRY","direction":"LONG","close":{{close}},"time":"{{time}}"}')

alertcondition(readyToEnterShort and sharesShort > 0,
   title="SID v1.2 - Short entry CONFIRMED",
   message='{"version":"1.2","strategy":"SID","symbol":"{{ticker}}","state":"ENTRY","direction":"SHORT","close":{{close}},"time":"{{time}}"}')

alertcondition((strategy.position_size > 0 and dailyRSI >= i_rsiExit) or (strategy.position_size < 0 and dailyRSI <= i_rsiExit),
   title="SID v1.2 - RSI 50 EXIT",
   message='{"version":"1.2","strategy":"SID","symbol":"{{ticker}}","state":"EXIT","reason":"RSI50","close":{{close}},"time":"{{time}}"}')
