//@version=6
// =============================================================================
// SID Strategy v1.7  — Instructor-aligned + RSI(3) + Weekly Trend + Earnings
// =============================================================================
// CORE RULES (instructor's method, untouched):
//   1. Signal:  RSI(14) crosses below 30 (LONG) or above 75 (SHORT). Arm STICKY.
//   2. Earnings: 14-day PRE-earnings blackout. Trading allowed the day after.
//                Earnings is forward-looking only (Pine `earnings.future_time`).
//   3. Entry:   On a LATER day (signal day + 1 to 3 trading days), when daily
//               RSI direction AND daily MACD direction both point in trade
//               direction. Entry is on that daily close.
//   4. Stop:    Lowest low (long) / highest high (short) between signal day
//               and entry day, rounded DOWN/UP to whole dollar.
//   5. Exit:    Daily RSI reaches 50. Single full exit.
//
// MINOR CONFIRMATION TWEAKS (each optional, default ON):
//   - 15-min intraday entry confirmation candle (v1.1)
//   - RSI(3) rebound-zone confirmation: 3-day RSI must also be in extreme
//     zone on the signal day (filters stale RSI(14) lag)  (v1.3)
//   - Weekly trend filter: longs only when weekly 50-SMA > 200-SMA; shorts
//     only when weekly 50-SMA < 200-SMA  (v1.4)
//   - Pre-earnings blackout enforced at entry-time (v1.7)
//
// VERSION HISTORY:
//   v1.0 — initial: simultaneous RSI+MACD daily-bar arm/entry
//   v1.1 — added 15-min intraday entry confirmation + 3-day timeout
//   v1.2 — INSTRUCTOR-ALIGNED FIX: sticky RSI signal; entry uses RSI+MACD
//          direction-align on later day (no requirement RSI stay in extreme)
//   v1.3 — RSI overbought raised 70->75 (cuts premature shorts) + RSI(3)
//          rebound-zone confirmation filter added
//   v1.4 — Weekly trend filter added. 12-month backtest on watchlist with
//          all filters active: 77% win rate, +$3,584 net on $10k account
//          at 2% risk per trade. ~36% annualized.
//   v1.5 — Pre-earnings blackout clarified: blocks 14 days BEFORE earnings
//          only (trading allowed the day after). 5-year backtest: WR 62.3%
//          vs v1.4 baseline 60.9%, PF 1.98 vs 1.85. v1.4 locked at git tag
//          `sid-v1.4-baseline`.
//   v1.6 — PPI blackout (14 days before US PPI release) + REFINED 47
//          watchlist curation (removed 14 net-losing community tickers).
//          FOMC/CPI blackouts TESTED and REJECTED — they hurt WR. 5-year
//          backtest on REFINED 47: WR 74.8%, PF 3.20, +$12,574. v1.5 locked
//          at tag `sid-v1.5-baseline`. PPI dates are enforced by the BOT
//          (event-dates.json); Pine for visualisation only.
//   v1.7 — VIX >= 30 gate + tier1 ticker expansion (80 active tickers).
//          Inspired by user spotting Sept 2022 FOMC + UK pension crisis
//          loss cluster. When VIX closes >= 30 the bot blocks new arms
//          for the day (existing positions continue). Sector ETF +
//          mega-cap stock additions broaden statistical sample without
//          diluting quality. v1.6 locked at tag `sid-v1.6-baseline`.
//          VIX gate is BOT-only (Pine has no native VIX integration).
//
// PROJECT POLICY: Per saved memory `feedback_instructor_strategy_priority.md`,
// the instructor's core rules (RSI 30 long signal, MACD alignment at entry,
// RSI 50 exit, 14-day earnings blackout) are non-negotiable. Everything in
// the "minor confirmation tweaks" section above is purely additive and
// makes the strategy MORE selective, not less. Turn them OFF in the inputs
// to revert to pure instructor v1.2 behavior.
// =============================================================================

strategy(
   "SID Strategy v1.7",
   shorttitle           = "SID v1.7",
   overlay              = true,
   initial_capital      = 10000,
   default_qty_type     = strategy.fixed,
   default_qty_value    = 0,
   pyramiding           = 0,
   process_orders_on_close = true,
   calc_on_every_tick   = false,
   commission_type      = strategy.commission.percent,
   commission_value     = 0.0,
   slippage             = 0
   )

// --- Inputs ----------------------------------------------------------------
g_strat = "Strategy"
i_accountSize   = input.float(10000.0, "Account size ($)", minval=100, group=g_strat)
i_riskPct       = input.float(2.0,    "Risk per trade (%)", minval=0.1, maxval=10.0, step=0.1, group=g_strat,
   tooltip="2% on $10k account = $200 risk per trade. With 77% backtest WR, increases to 3% are defensible.")
i_rsiOversold   = input.int(30,       "RSI(14) oversold (long signal)",  minval=10, maxval=45, group=g_strat)
i_rsiOverbought = input.int(75,       "RSI(14) overbought (short signal)", minval=55, maxval=90, group=g_strat,
   tooltip="v1.3 raised from 70 to 75 to filter premature shorts on bullish trend stocks.")
i_rsiExit       = input.int(50,       "RSI exit level", minval=30, maxval=70, group=g_strat)
i_timeoutDays   = input.int(3,        "Hard timeout (trading days)", minval=1, maxval=10, group=g_strat)

g_filt = "Direction filters"
i_allowLongs    = input.bool(true,  "Allow long trades",  group=g_filt)
i_allowShorts   = input.bool(true,  "Allow short trades", group=g_filt,
   tooltip="Per the classification report, some bullish-trend stocks should be set to long-only here.")
i_useEarnings   = input.bool(true,  "Apply 14-day earnings blackout", group=g_filt)
i_earningsDays  = input.int(14,     "Earnings blackout days", minval=1, maxval=30, group=g_filt)

g_conf = "Confirmation tweaks (additive, default ON)"
i_useIntraday   = input.bool(true,  "15-min intraday entry confirmation (v1.1)",  group=g_conf,
   tooltip="Requires a 15-min candle in trade direction during US session after daily alignment. Filters fake reversals.")
i_useRsi3       = input.bool(true,  "RSI(3) rebound-zone confirmation (v1.3)", group=g_conf,
   tooltip="3-day RSI must also be in extreme zone on signal day. Confirms the rebound is FRESH, not a stale RSI(14) lag.")
i_useWeeklyTrend = input.bool(true, "Weekly trend filter (v1.4)", group=g_conf,
   tooltip="Longs only allowed in weekly uptrend (50w SMA > 200w SMA); shorts only in weekly downtrend. The single biggest quality uplift in backtest.")
i_rsi3Period    = input.int(3,      "RSI(3) period", minval=2, maxval=10, group=g_conf)
i_wkFastSMA     = input.int(50,     "Weekly fast SMA", minval=10, maxval=100, group=g_conf)
i_wkSlowSMA     = input.int(200,    "Weekly slow SMA", minval=50, maxval=300, group=g_conf)

g_disp = "Display"
i_showTable   = input.bool(true,  "Show info table", group=g_disp)
i_showSignals = input.bool(true,  "Show signal + entry markers", group=g_disp)
i_showStops   = input.bool(true,  "Show stop line while in trade", group=g_disp)

// --- Daily-timeframe values ------------------------------------------------
[macdLine_, _, _] = ta.macd(close, 12, 26, 9)

dailyRSI       = request.security(syminfo.tickerid, "D", ta.rsi(close, 14),       lookahead=barmerge.lookahead_off)
dailyRSIPrev   = request.security(syminfo.tickerid, "D", ta.rsi(close, 14)[1],    lookahead=barmerge.lookahead_off)
dailyRSI3      = request.security(syminfo.tickerid, "D", ta.rsi(close, i_rsi3Period), lookahead=barmerge.lookahead_off)
dailyMACDLine  = request.security(syminfo.tickerid, "D", macdLine_,               lookahead=barmerge.lookahead_off)
dailyMACDPrev  = request.security(syminfo.tickerid, "D", macdLine_[1],            lookahead=barmerge.lookahead_off)
dailyLow       = request.security(syminfo.tickerid, "D", low,                     lookahead=barmerge.lookahead_off)
dailyHigh      = request.security(syminfo.tickerid, "D", high,                    lookahead=barmerge.lookahead_off)

rsiRising      = dailyRSI > dailyRSIPrev
rsiFalling     = dailyRSI < dailyRSIPrev
macdRising     = dailyMACDLine > dailyMACDPrev
macdFalling    = dailyMACDLine < dailyMACDPrev

// --- Weekly trend filter ---------------------------------------------------
weeklyFastSMA  = request.security(syminfo.tickerid, "W", ta.sma(close, i_wkFastSMA), lookahead=barmerge.lookahead_off)
weeklySlowSMA  = request.security(syminfo.tickerid, "W", ta.sma(close, i_wkSlowSMA), lookahead=barmerge.lookahead_off)
weeklyUptrend     = not na(weeklyFastSMA) and not na(weeklySlowSMA) and weeklyFastSMA > weeklySlowSMA
weeklyDowntrend   = not na(weeklyFastSMA) and not na(weeklySlowSMA) and weeklyFastSMA < weeklySlowSMA

// --- Earnings filter -------------------------------------------------------
nextEarningsTime = request.security(syminfo.tickerid, "D", earnings.future_time, ignore_invalid_symbol=true, lookahead=barmerge.lookahead_off)
hasEarnings      = not na(nextEarningsTime)
daysToEarnings   = hasEarnings ? math.floor((nextEarningsTime - time) / (1000.0 * 60.0 * 60.0 * 24.0)) : 9999
earningsBlackout = i_useEarnings and hasEarnings and daysToEarnings <= i_earningsDays

// --- Daily-bar boundary detection ------------------------------------------
isNewDailyBar = ta.change(time("D")) != 0

// --- Signal arming (instructor rule 1 + minor confirmation filters) --------
isOversold   = dailyRSI < i_rsiOversold
isOverbought = dailyRSI > i_rsiOverbought

// RSI(3) confirmation filter (v1.3) — disabled if toggle off
rsi3OkLong   = not i_useRsi3 or (not na(dailyRSI3) and dailyRSI3 < i_rsiOversold)
rsi3OkShort  = not i_useRsi3 or (not na(dailyRSI3) and dailyRSI3 > i_rsiOverbought)

// Weekly trend filter (v1.4) — disabled if toggle off
wkOkLong  = not i_useWeeklyTrend or weeklyUptrend
wkOkShort = not i_useWeeklyTrend or weeklyDowntrend

var string armDir          = na
var float  armSignalLow    = na
var float  armSignalHigh   = na
var int    daysSinceArm    = 0

canArm = na(armDir) and strategy.position_size == 0 and not earningsBlackout

shouldArmLong  = isNewDailyBar and canArm and i_allowLongs  and isOversold   and rsi3OkLong  and wkOkLong
shouldArmShort = isNewDailyBar and canArm and i_allowShorts and isOverbought and rsi3OkShort and wkOkShort

if shouldArmLong
    armDir       := "LONG"
    armSignalLow  := dailyLow
    armSignalHigh := dailyHigh
    daysSinceArm  := 0
if shouldArmShort
    armDir       := "SHORT"
    armSignalLow  := dailyLow
    armSignalHigh := dailyHigh
    daysSinceArm  := 0

if not na(armDir) and isNewDailyBar and not (shouldArmLong or shouldArmShort)
    daysSinceArm  := daysSinceArm + 1
    armSignalLow  := math.min(armSignalLow,  dailyLow)
    armSignalHigh := math.max(armSignalHigh, dailyHigh)

// Invalidate: timeout or earnings (per instructor)
if (armDir == "LONG" or armDir == "SHORT") and isNewDailyBar and (daysSinceArm >= i_timeoutDays or earningsBlackout)
    armDir       := na
    armSignalLow  := na
    armSignalHigh := na
    daysSinceArm  := 0

// --- Entry conditions (instructor rule 3) ----------------------------------
dailyEntryArmedLong  = armDir == "LONG"  and isNewDailyBar and rsiRising  and macdRising
dailyEntryArmedShort = armDir == "SHORT" and isNewDailyBar and rsiFalling and macdFalling

var bool dailyReadyLong  = false
var bool dailyReadyShort = false
if isNewDailyBar
    dailyReadyLong  := dailyEntryArmedLong
    dailyReadyShort := dailyEntryArmedShort

inUSSession = not na(time(timeframe.period, "0930-1600", "America/New_York"))
candleGreen = close > open
candleRed   = close < open

readyToEnterLong  = i_useIntraday ? (dailyReadyLong  and armDir == "LONG"  and inUSSession and candleGreen) : dailyEntryArmedLong
readyToEnterShort = i_useIntraday ? (dailyReadyShort and armDir == "SHORT" and inUSSession and candleRed)   : dailyEntryArmedShort

// --- Position sizing -------------------------------------------------------
riskAmount = i_accountSize * (i_riskPct / 100.0)
stopLong   = na(armSignalLow)  ? na : math.floor(armSignalLow)
stopShort  = na(armSignalHigh) ? na : math.ceil(armSignalHigh)

riskPerShareLong  = readyToEnterLong  and not na(stopLong)  ? close - stopLong  : na
riskPerShareShort = readyToEnterShort and not na(stopShort) ? stopShort - close : na

sharesLong  = not na(riskPerShareLong)  and riskPerShareLong  > 0 ? math.floor(riskAmount / riskPerShareLong)  : 0
sharesShort = not na(riskPerShareShort) and riskPerShareShort > 0 ? math.floor(riskAmount / riskPerShareShort) : 0

// --- Execute entries -------------------------------------------------------
if readyToEnterLong and sharesLong > 0
    strategy.entry("Long", strategy.long, qty=sharesLong)
    strategy.exit("Stop L", from_entry="Long", stop=stopLong)
    armDir         := na
    armSignalLow   := na
    armSignalHigh  := na
    daysSinceArm   := 0
    dailyReadyLong := false

if readyToEnterShort and sharesShort > 0
    strategy.entry("Short", strategy.short, qty=sharesShort)
    strategy.exit("Stop S", from_entry="Short", stop=stopShort)
    armDir          := na
    armSignalLow    := na
    armSignalHigh   := na
    daysSinceArm    := 0
    dailyReadyShort := false

// --- Exit on daily RSI = 50 (instructor rule 5) ----------------------------
if strategy.position_size > 0 and dailyRSI >= i_rsiExit
    strategy.close("Long", comment="RSI 50 exit")
if strategy.position_size < 0 and dailyRSI <= i_rsiExit
    strategy.close("Short", comment="RSI 50 exit")

// --- On-chart markers ------------------------------------------------------
plotshape(i_showSignals and shouldArmLong,  title="Long signal armed",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.yellow, 0), size=size.tiny)
plotshape(i_showSignals and shouldArmShort, title="Short signal armed", style=shape.triangledown, location=location.abovebar, color=color.new(color.yellow, 0), size=size.tiny)
plotshape(i_showSignals and readyToEnterLong  and sharesLong  > 0, title="Long entry",  style=shape.arrowup,   location=location.belowbar, color=color.new(color.lime, 0),    size=size.large)
plotshape(i_showSignals and readyToEnterShort and sharesShort > 0, title="Short entry", style=shape.arrowdown, location=location.abovebar, color=color.new(color.fuchsia, 0), size=size.large)

exitLong  = strategy.position_size[1] > 0 and dailyRSI >= i_rsiExit
exitShort = strategy.position_size[1] < 0 and dailyRSI <= i_rsiExit
plotshape(i_showSignals and exitLong,  title="Long exit",  style=shape.xcross, location=location.abovebar, color=color.new(color.orange, 0), size=size.normal)
plotshape(i_showSignals and exitShort, title="Short exit", style=shape.xcross, location=location.belowbar, color=color.new(color.orange, 0), size=size.normal)

inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0
plot(i_showStops and inLong  ? strategy.position_avg_price : na, "Long entry price",  color=color.new(color.green, 50), style=plot.style_circles, linewidth=1)
plot(i_showStops and inShort ? strategy.position_avg_price : na, "Short entry price", color=color.new(color.red,   50), style=plot.style_circles, linewidth=1)

// --- Info table ------------------------------------------------------------
if i_showTable and barstate.islast
    var table info = table.new(position.top_right, 2, 12, bgcolor=color.new(color.black, 70), border_width=1, border_color=color.new(color.gray, 50))

    state     = strategy.position_size != 0 ? (inLong ? "IN TRADE (LONG)" : "IN TRADE (SHORT)") : (na(armDir) ? "IDLE" : "ARMED " + armDir)
    rsiColor  = dailyRSI < i_rsiOversold ? color.lime : dailyRSI > i_rsiOverbought ? color.red : color.white
    rsi3Color = dailyRSI3 < i_rsiOversold ? color.lime : dailyRSI3 > i_rsiOverbought ? color.red : color.white
    macdTxt   = macdRising ? "rising" : macdFalling ? "falling" : "flat"
    macdCol   = macdRising ? color.lime : macdFalling ? color.red : color.gray
    rsiDirTxt = rsiRising ? "rising" : rsiFalling ? "falling" : "flat"
    rsiDirCol = rsiRising ? color.lime : rsiFalling ? color.red : color.gray
    wkTxt     = weeklyUptrend ? "UP" : weeklyDowntrend ? "DOWN" : "FLAT"
    wkCol     = weeklyUptrend ? color.lime : weeklyDowntrend ? color.red : color.gray
    earnTxt   = not hasEarnings ? "none" : (daysToEarnings <= i_earningsDays ? "BLACKOUT " + str.tostring(daysToEarnings) + "d" : str.tostring(daysToEarnings) + "d")
    earnCol   = earningsBlackout ? color.red : color.white
    stopTxt   = armDir == "LONG" ? "$" + str.tostring(stopLong, "#.##") : armDir == "SHORT" ? "$" + str.tostring(stopShort, "#.##") : "—"

    table.cell(info, 0, 0,  "SID Strategy v1.4", text_color=color.white, bgcolor=color.new(color.blue, 40))
    table.cell(info, 1, 0,  syminfo.ticker,      text_color=color.white, bgcolor=color.new(color.blue, 40))
    table.cell(info, 0, 1,  "State",            text_color=color.gray)
    table.cell(info, 1, 1,  state,              text_color=color.yellow)
    table.cell(info, 0, 2,  "Daily RSI(14)",    text_color=color.gray)
    table.cell(info, 1, 2,  str.tostring(dailyRSI, "#.#"), text_color=rsiColor)
    table.cell(info, 0, 3,  "RSI(3)",           text_color=color.gray)
    table.cell(info, 1, 3,  str.tostring(dailyRSI3, "#.#"), text_color=rsi3Color)
    table.cell(info, 0, 4,  "Weekly trend",     text_color=color.gray)
    table.cell(info, 1, 4,  wkTxt,              text_color=wkCol)
    table.cell(info, 0, 5,  "RSI direction",    text_color=color.gray)
    table.cell(info, 1, 5,  rsiDirTxt,          text_color=rsiDirCol)
    table.cell(info, 0, 6,  "MACD direction",   text_color=color.gray)
    table.cell(info, 1, 6,  macdTxt,            text_color=macdCol)
    table.cell(info, 0, 7,  "Days armed",       text_color=color.gray)
    table.cell(info, 1, 7,  na(armDir) ? "—" : str.tostring(daysSinceArm) + " / " + str.tostring(i_timeoutDays), text_color=color.white)
    table.cell(info, 0, 8,  "Earnings",         text_color=color.gray)
    table.cell(info, 1, 8,  earnTxt,            text_color=earnCol)
    table.cell(info, 0, 9,  "Stop level",       text_color=color.gray)
    table.cell(info, 1, 9,  stopTxt,            text_color=color.white)
    table.cell(info, 0, 10, "Risk per trade",   text_color=color.gray)
    table.cell(info, 1, 10, "$" + str.tostring(riskAmount, "#.##") + "  (" + str.tostring(i_riskPct) + "%)", text_color=color.white)
    table.cell(info, 0, 11, "Account",          text_color=color.gray)
    table.cell(info, 1, 11, "$" + str.tostring(i_accountSize, "#.##"), text_color=color.white)

// --- Alerts (webhook-ready JSON payloads) ---------------------------------
alertcondition(shouldArmLong,   title="SID v1.4 - Long signal ARMED",  message='{"version":"1.4","strategy":"SID","symbol":"{{ticker}}","state":"ARMED","direction":"LONG","close":{{close}},"time":"{{time}}"}')
alertcondition(shouldArmShort,  title="SID v1.4 - Short signal ARMED", message='{"version":"1.4","strategy":"SID","symbol":"{{ticker}}","state":"ARMED","direction":"SHORT","close":{{close}},"time":"{{time}}"}')
alertcondition(readyToEnterLong  and sharesLong  > 0, title="SID v1.4 - Long entry CONFIRMED",  message='{"version":"1.4","strategy":"SID","symbol":"{{ticker}}","state":"ENTRY","direction":"LONG","close":{{close}},"time":"{{time}}"}')
alertcondition(readyToEnterShort and sharesShort > 0, title="SID v1.4 - Short entry CONFIRMED", message='{"version":"1.4","strategy":"SID","symbol":"{{ticker}}","state":"ENTRY","direction":"SHORT","close":{{close}},"time":"{{time}}"}')
alertcondition((strategy.position_size > 0 and dailyRSI >= i_rsiExit) or (strategy.position_size < 0 and dailyRSI <= i_rsiExit),
   title="SID v1.4 - RSI 50 EXIT",
   message='{"version":"1.4","strategy":"SID","symbol":"{{ticker}}","state":"EXIT","reason":"RSI50","close":{{close}},"time":"{{time}}"}')
